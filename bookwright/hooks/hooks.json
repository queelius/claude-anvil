{
  "description": "bookwright LaTeX-macro-leak prevention",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/check-latex-macro-leak.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
